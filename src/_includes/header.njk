    <header class="site-header">
      <a class="brand" href="/" aria-label="{{ site.orgFull }}">
        <span class="brand-mark">{{ site.orgShort }}</span>
      </a>
      <button class="nav-toggle" type="button" aria-label="Меню" aria-expanded="false"><span></span></button>
      <nav class="nav" aria-label="Головна навігація">
        {%- for item in site.nav %}
        <a href="{{ item.href }}"{% if page.url == item.href %} class="active"{% endif %}>{{ item.label }}</a>
        {%- endfor %}
      </nav>
      <div class="header-right">
        <div class="lang-select-wrap">
          <select class="lang-select" aria-label="Мова" onchange="document.documentElement.lang=this.value==='en'?'en':'uk'">
            <option value="uk">UA</option>
            <option value="en">EN</option>
          </select>
        </div>
        <a class="hotline-pill" href="tel:{{ site.hotlineTel }}">
          <span class="hotline-pill-text">
            <span class="hotline-pill-label">Гаряча лінія</span>
            <strong class="hotline-pill-number">{{ site.hotline }}</strong>
          </span>
          <span class="hotline-pill-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.29 6.29l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
        </a>
        <a class="btn-support" href="{{ site.donateUrl }}">
          Підтримати
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
      </div>
    </header>
