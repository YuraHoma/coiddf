    <header class="site-header">
      <a class="brand" href="/" aria-label="{{ site.orgFull }}">
        <span class="brand-mark">{% include "logo.njk" %}</span>
      </a>
      <button class="nav-toggle" type="button" aria-label="Меню" aria-expanded="false"><span></span></button>
      <nav class="nav" aria-label="Головна навігація">
        {%- for item in site.nav %}
        <a href="{{ item.href }}"{% if page.url == item.href %} class="active"{% endif %}>{{ item.label }}</a>
        {%- endfor %}
      </nav>
      <div class="header-right">
        <div class="lang-select-wrap">
          <select class="lang-select" aria-label="Мова" onchange="document.documentElement.lang=this.value==='en'?'en':'uk'">
            <option value="uk">UA</option>
            <option value="en">EN</option>
          </select>
        </div>
        <a class="btn-support" href="{{ site.contactUrl }}">
          Зв'язатися з нами
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
      </div>
    </header>
