<!doctype html>
<html lang="uk">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description or excerpt }}">
    {%- if noindex %}
    <meta name="robots" content="noindex">
    {%- else %}
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    {%- endif %}
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
    <meta name="theme-color" content="#5A7D3D">
    <meta property="og:type" content="{% if page.url and '/novyny/' in page.url and page.url != '/novyny/' %}article{% else %}website{% endif %}">
    <meta property="og:site_name" content="{{ site.orgFull }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description or excerpt }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:image" content="{{ site.url }}{{ image or '/assets/og-image.jpg' }}">
    <meta property="og:locale" content="uk_UA">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Onest:wght@300..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
{% include "header.njk" %}
    <main>
{{ content | safe }}
    </main>
{% include "footer.njk" %}
    <script>
      (function () {
        var d = document, root = d.documentElement;
        root.classList.add('js');

        var header = d.querySelector('.site-header');
        var toggle = d.querySelector('.nav-toggle');

        if (header && toggle) {
          toggle.addEventListener('click', function () {
            var open = header.classList.toggle('nav-open');
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          });
          header.querySelectorAll('.nav a').forEach(function (a) {
            a.addEventListener('click', function () {
              header.classList.remove('nav-open');
              toggle.setAttribute('aria-expanded', 'false');
            });
          });
        }

        var lastY = 0, ticking = false;
        window.addEventListener('scroll', function () {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(function () {
            var y = window.pageYOffset || 0;
            if (header) header.classList.toggle('scrolled', y > 24);
            if (header && !header.classList.contains('nav-open')) {
              if (y > 120 && y > lastY) header.classList.add('header-hidden');
              else header.classList.remove('header-hidden');
            }
            lastY = y;
            ticking = false;
          });
        }, { passive: true });

        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        /* ротація акцентного слова в H1 (2.2s). Ширина фіксується під
           найдовше слово, щоб заголовок не перескакував між словами. */
        var accent = d.querySelector('.hero-top h1 .accent');
        if (accent && !reduce) {
          var words = ['націю', 'родини', 'громади', 'майбутнє'];
          var wi = Math.max(0, words.indexOf(accent.textContent.trim()));
          var show = 'opacity 280ms ease, transform 280ms ease';
          accent.style.display = 'inline-block';
          accent.style.transition = show;
          var maxWidth = 0;
          words.forEach(function (w) {
            accent.textContent = w;
            maxWidth = Math.max(maxWidth, accent.getBoundingClientRect().width);
          });
          accent.style.width = Math.ceil(maxWidth) + 'px';
          accent.textContent = words[wi];
          setInterval(function () {
            accent.style.opacity = '0';
            accent.style.transform = 'translateY(0.45em)';
            setTimeout(function () {
              wi = (wi + 1) % words.length;
              accent.textContent = words[wi];
              accent.style.transition = 'none';
              accent.style.transform = 'translateY(-0.45em)';
              void accent.offsetHeight;
              accent.style.transition = show;
              accent.style.opacity = '1';
              accent.style.transform = 'translateY(0)';
            }, 300);
          }, 2200);
        }
        if (reduce || !('IntersectionObserver' in window)) return;
        var sel = '.section-heading,.intro-photos,.intro-story-top > p,' +
          '.map-card,.cards-grid article,.process-grid article,.feature-copy,.feature-gallery,' +
          '.resource-card,.partner-marquee,.partner-detail-card,.news-mini-grid article,.news-grid article,' +
          '.principles-grid article,.about-note,.about-copy,.team-grid article,.feedback-form,' +
          '.project-list > *,.contact-list span,.awards-placeholder,.cta-band > div';
        var els = [].slice.call(d.querySelectorAll(sel));
        els.forEach(function (el) {
          el.setAttribute('data-reveal', '');
          var p = el.parentNode, idx = p ? [].indexOf.call(p.children, el) : 0;
          el.style.transitionDelay = (Math.min(idx, 6) * 60) + 'ms';
        });
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
