---
layout: base.njk
---
{% import "news-card.njk" as news %}
      <section class="page-hero">
        <div>
          <p class="eyebrow">Новини</p>
          <h1>{{ title }}</h1>
          <p class="lead">{{ date | uadate }}</p>
        </div>
      </section>
      <article class="section news-article">
        {% if image %}<img class="news-article-cover" src="{{ image }}" alt="{{ title }}">{% endif %}
        <div class="news-article-body">
          {% if excerpt %}<p class="news-article-lead">{{ excerpt }}</p>{% endif %}
          {{ content | safe }}
        </div>
      </article>
      <section class="section section-light news-more">
        <div class="section-heading">
          <p class="eyebrow">Новини</p>
          <h2>Інші новини</h2>
        </div>
        <div class="news-mini-grid">
          {%- set shown = 0 -%}
          {%- for post in collections.news -%}
          {%- if post.url != page.url and shown < 3 -%}
{{ news.newsCard(post, false) }}
          {%- set shown = shown + 1 -%}
          {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="news-all-wrap">
          <a class="button button-outline" href="/novyny/">Усі новини ↗</a>
        </div>
      </section>
