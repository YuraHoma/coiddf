---
layout: base.njk
permalink: /proyekty/
title: Проєкти | Фонд розвитку міжнародної співпраці
description: Гуманітарні, освітні та відновлювальні проєкти фонду.
---
      <section class="page-hero">
        <div>
          <p class="eyebrow">{{ proyekty.hero.eyebrow }}</p>
          <h1>{{ proyekty.hero.heading }}</h1>
          <p class="lead">{{ proyekty.hero.lead }}</p>
        </div>
      </section>
      <section class="section section-light">
        <div class="project-list">
          {%- for p in collections.projects %}
          <article>
            <span>{{ p.data.date | uadate }}</span>
            <h3>{{ p.data.title }}</h3>
            <p>{{ p.data.excerpt }}</p>
          </article>
          {%- endfor %}
        </div>
      </section>
      <section class="section">
        <div class="section-heading"><h2>{{ proyekty.model.heading }}</h2></div>
        <div class="info-grid">
          {%- for it in proyekty.model.items %}
          <article><h3>{{ it.title }}</h3><p>{{ it.text }}</p></article>
          {%- endfor %}
        </div>
      </section>
