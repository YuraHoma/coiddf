---
layout: base.njk
permalink: /
title: Фонд розвитку міжнародної співпраці | Гуманітарна допомога
description: Головна сторінка благодійного фонду.
---
{% import "icons.njk" as icons %}
{% import "news-card.njk" as news %}
{% import "partner-logos.njk" as logos %}
      <section class="home-hero">
        <div class="hero-top">
          <div class="hero-headline">
            <p class="hero-org">{{ home.hero.orgBanner | safe }}</p>
            <h1>{{ home.hero.headline | safe }}</h1>
            <p class="lead">{{ home.hero.lead }}</p>
            <div class="hero-actions">
              <a class="button button-accent" href="{{ site.contactUrl }}">{{ home.hero.primaryLabel }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
              <a class="button button-ghost" href="{{ home.hero.secondaryUrl }}">{{ home.hero.secondaryLabel }}</a>
            </div>
          </div>
          <figure class="hero-figure">
            <img src="{{ home.hero.image }}" alt="{{ home.hero.imageAlt }}" loading="eager" fetchpriority="high" sizes="(min-width: 901px) 50vw, 100vw">
          </figure>
        </div>
      </section>
      <section class="section partners-section">
        <div class="section-heading center"><p class="eyebrow">{{ home.partners.eyebrow }}</p></div>
        <div class="partner-marquee">
          <div class="partner-track">
            {%- for p in partners.items %}
            <div class="partner-logo-card">{{ logos.logo(p.key) }}</div>
            {%- endfor %}
            {%- for p in partners.items %}
            <div class="partner-logo-card">{{ logos.logo(p.key) }}</div>
            {%- endfor %}
          </div>
        </div>
      </section>
      <section class="section">
        <div class="section-heading center">
          <p class="eyebrow">{{ home.focusAreas.eyebrow }}</p>
          <h2>{{ home.focusAreas.heading }}</h2>
        </div>
        <div class="cards-grid">
          {%- for c in home.focusAreas.items %}
          <article>
            <h3>{{ c.title }}</h3>
            <p>{{ c.text }}</p>
          </article>
          {%- endfor %}
        </div>
      </section>
      <section class="section focus-map">
        <div class="section-heading center">
          <p class="eyebrow">{{ home.geography.eyebrow }}</p>
          <h2>{{ home.geography.heading }}</h2>
        </div>
        <div class="map-card">
          <img src="/assets/map-ukraine-oblasts.svg" alt="Карта областей України; Запорізька область — домашній регіон фонду — виділена кольором" loading="lazy" eleventy:ignore>
        </div>
      </section>
      <section class="section process-section">
        <div class="process-panel">
          <div class="section-heading center">
            <p class="eyebrow">{{ home.process.eyebrow }}</p>
            <h2>{{ home.process.heading }}</h2>
          </div>
          <div class="process-grid">
            {%- for s in home.process.steps %}
            <article><span>{{ loop.index }}</span><h3>{{ s.title }}</h3><p>{{ s.text }}</p></article>
            {%- endfor %}
          </div>
          <a class="wide-action" href="{{ home.process.ctaUrl }}">{{ home.process.ctaLabel }} <span>↗</span></a>
        </div>
      </section>
      <section class="section infra-section">
        <div class="section-heading center"><h2>{{ home.resources.heading }}</h2></div>
        <div class="report-list">
          {%- for r in home.resources.items %}
          <div class="resource-card">
            <span class="resource-icon">{{ icons.resourceIcon(r.icon) }}</span>
            <span>{{ r.title }}{% if r.strong %}<strong>{{ r.strong }}</strong>{% endif %}{{ r.sub }}</span>
          </div>
          {%- endfor %}
        </div>
      </section>
      <section class="section news-preview">
        <div class="section-heading center">
          <p class="eyebrow">Новини</p>
          <h2>{{ home.newsHeading }}</h2>
        </div>
        <div class="news-mini-grid">
          {%- for post in collections.news %}{% if loop.index <= 3 %}
{{ news.newsCard(post, false) }}
          {%- endif %}{% endfor %}
        </div>
        <div class="news-all-wrap">
          <a class="button button-outline news-all-btn" href="/novyny/">Усі новини ↗</a>
        </div>
      </section>
      <section class="cta-band">
        <div>
          <h2>{{ home.cta.heading }}</h2>
          <a class="button button-accent" href="{{ site.contactUrl }}">{{ home.cta.buttonLabel }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
        </div>
      </section>
