      <section class="page-hero section-dark">
        <div>
          <p class="eyebrow">{{ contacts.hero.eyebrow }}</p>
          <h1>{{ contacts.hero.heading }}</h1>
          <p class="lead">{{ contacts.hero.lead }}</p>
        </div>
      </section>
      <section class="section contacts-page">
        <div class="contact-list">
          {%- for c in contacts.items %}
          <span>{{ c.label }}: {{ c.value }}</span>
          {%- endfor %}
        </div>
      </section>
